        // Kills dev servers (ports 3000/4000), Tauri, Capacitor, Vitest watch,
        // and Maestro. Terminals with close: true vanish automatically.
        {
            "label": "⚡ Stop: All",
            "type": "shell",
            "command": "for pid in $(lsof -ti:3000,4000 2>/dev/null) $(pgrep -f vitest 2>/dev/null) $(pgrep -f maestro 2>/dev/null) $(pgrep -f 'cargo run' 2>/dev/null) $(pgrep -f 'cap run' 2>/dev/null); do pgid=$(ps -o pgid= -p $pid 2>/dev/null | tr -d ' '); [ -n \"$pgid\" ] && kill -- -$pgid 2>/dev/null; done; sleep 0.5; echo 'All tasks stopped'",
            "presentation": { "panel": "shared", "reveal": "silent", "close": true },
            "problemMatcher": []
        },


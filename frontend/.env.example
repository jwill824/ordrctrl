# Backend API URL (internal)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Environment
NODE_ENV="development"

# Dev-only: auto-populate Apple credential form in local development
# Set these to skip manual entry when testing the Apple integration locally
NEXT_PUBLIC_DEV_APPLE_USERNAME=""
NEXT_PUBLIC_DEV_APPLE_APP_SPECIFIC_PASSWORD=""
